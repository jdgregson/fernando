# Fernando Configuration
# Copy this file to config and customize for your deployment
# Format: KEY=VALUE (one per line, same as environment variables)

# Allowed origins for WebSocket connections (comma-separated)
ALLOWED_ORIGINS=https://fernando.yourdomain.com

# Nginx settings (user-facing)
NGINX_HOST=127.0.0.1
NGINX_PORT=8080

# Flask backend settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Debug mode
DEBUG=false

# Tmux settings
TMUX_HISTORY_LINES=32768

# Brave Search API (https://api.search.brave.com/register)
# BRAVE_SEARCH_API_KEY=your-search-api-key
# BRAVE_ANSWERS_API_KEY=your-answers-api-key

# GitHub Personal Access Token (https://github.com/settings/tokens)
# GITHUB_PAT=your-github-pat

# Cloudflare API Token (https://dash.cloudflare.com/profile/api-tokens)
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token